# Copy this file to .env.local and paste your REAL Neon connection string.
# In Cursor: right-click this file → Copy, paste as .env.local in project root.
#
# Get the string from: https://console.neon.tech → your project → Connect
# It looks like: postgresql://neondb_owner:abc123...@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

DATABASE_URL=postgresql://REPLACE_WITH_YOUR_NEON_CONNECTION_STRING
NEXT_PUBLIC_SITE_URL=https://clearchoicepharmacy.com

# Stripe — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE
STRIPE_SECRET_KEY=sk_test_REPLACE
# Stripe webhook signing secret — https://dashboard.stripe.com/webhooks (endpoint: /api/webhooks/stripe)
STRIPE_WEBHOOK_SECRET=whsec_REPLACE

# AWS S3 — private storage for prescriptions, intake IDs (see docs/S3_SETUP.md)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
INTAKE_ID_BUCKET=

# AWS SES — intake approval/denial emails + clinician alerts (see docs/SES_SETUP.md)
SES_SENDER_EMAIL=intake@clearchoicepharmacy.com
DR_DOURRA_EMAIL=
TELEHEALTH_CLINICIAN_EMAIL=
# Optional recipient for: npm run ses:verify
SES_VERIFY_TO=
